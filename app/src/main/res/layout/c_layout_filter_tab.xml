<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filtros"
        style="@style/TS_Title3"
        android:visibility="gone"
        android:textColor="@color/color5"/>

    <com.podcast.renerd.components.buttons.DefaultButton
        android:id="@+id/button_toggle_all"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        app:icon="@drawable/icon_check"
        app:label="Selecionar todos"
        app:default_width="false"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview_base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
